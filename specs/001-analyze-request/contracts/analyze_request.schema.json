{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "analyze_request MCP Tool Schema",
  "description": "Slackスレッドの依頼を分析し、構造化された結果を返すMCPツール",

  "tool": {
    "name": "analyze_request",
    "description": "Slackスレッドの依頼を分析し、目的・不明点・確認メッセージ案・ネクストアクションを構造化して返す",
    "inputSchema": {
      "type": "object",
      "properties": {
        "thread_content": {
          "type": "string",
          "description": "分析対象のSlackスレッド内容（get_slack_threadの出力）"
        },
        "thread_url": {
          "type": "string",
          "description": "SlackスレッドのURL（参照用）"
        },
        "analysis": {
          "$ref": "#/definitions/AnalysisResult",
          "description": "Claudeが生成した分析結果"
        }
      },
      "required": ["thread_content", "analysis"]
    }
  },

  "definitions": {
    "AnalysisResult": {
      "type": "object",
      "properties": {
        "purpose": {
          "type": "string",
          "description": "依頼の目的（1文で言語化）",
          "maxLength": 500
        },
        "deliverable": {
          "type": ["string", "null"],
          "description": "成果物（不明な場合はnull）"
        },
        "deadline": {
          "type": ["string", "null"],
          "description": "期限（不明な場合はnull）"
        },
        "unclear_points": {
          "type": "array",
          "items": { "$ref": "#/definitions/UnclearPoint" },
          "description": "不明点のリスト"
        },
        "confirmation_message": {
          "type": ["string", "null"],
          "description": "確認メッセージ案（不明点がない場合はnull）"
        },
        "next_action": {
          "$ref": "#/definitions/NextAction",
          "description": "ネクストアクション"
        },
        "priority": {
          "$ref": "#/definitions/Priority",
          "description": "優先度"
        }
      },
      "required": ["purpose", "unclear_points", "next_action", "priority"]
    },

    "UnclearPoint": {
      "type": "object",
      "properties": {
        "question": {
          "type": "string",
          "description": "確認すべき質問",
          "maxLength": 200
        },
        "impact": {
          "type": "string",
          "description": "この点が不明だと何が困るか",
          "maxLength": 200
        },
        "suggested_options": {
          "type": "array",
          "items": { "type": "string" },
          "description": "想定される選択肢"
        }
      },
      "required": ["question", "impact"]
    },

    "NextAction": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string",
          "description": "具体的なアクション内容",
          "maxLength": 200
        },
        "estimated_time": {
          "type": "integer",
          "description": "推定所要時間（分）",
          "minimum": 1,
          "maximum": 30
        },
        "reason": {
          "type": ["string", "null"],
          "description": "なぜこれが最初のアクションなのか"
        }
      },
      "required": ["action", "estimated_time"]
    },

    "Priority": {
      "type": "string",
      "enum": ["high", "medium", "low"],
      "description": "優先度（high: 他の人をブロック/期限近い, medium: 今日〜今週中, low: いつでもいい）"
    }
  },

  "outputSchema": {
    "type": "object",
    "properties": {
      "success": {
        "type": "boolean",
        "description": "処理成功フラグ"
      },
      "message": {
        "type": "string",
        "description": "処理結果メッセージ"
      },
      "analysis": {
        "$ref": "#/definitions/AnalysisResult",
        "description": "保存された分析結果"
      }
    },
    "required": ["success", "message"]
  }
}
